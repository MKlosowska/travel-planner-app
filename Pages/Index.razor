@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="hero">
    <div class="hero-dashboard">
        <div>
            <h1>Travel Planner</h1>
            <p>Zorganizuj swoje wyjazdy, dokumenty PDF, budżet, wydatki, zdjęcia, lokalizacje i listę pakowania w jednym miejscu.</p>
            <div class="hero-actions">
                <a href="trips" class="button primary">Przejdź do podróży</a>
                <a href="settings" class="button">Ustawienia</a>
            </div>
        </div>
    </div>
</div>

<div class="feature-grid">
    <div class="feature-card">
        <h3>Podróże</h3>
        <p>Tworzenie, edycja i planowanie wyjazdów.</p>
    </div>
    <div class="feature-card">
        <h3>Budżet</h3>
        <p>Kontrola wydatków i limitów finansowych.</p>
    </div>
    <div class="feature-card">
        <h3>Dokumenty</h3>
        <p>Przechowywanie biletów i rezerwacji PDF.</p>
    </div>
    <div class="feature-card">
        <h3>Mapa</h3>
        <p>Interaktywne oznaczanie punktów podróży.</p>
    </div>
    <div class="feature-card">
        <h3>Pakowanie</h3>
        <p>Wygodne listy i automatyczny eksport PDF.</p>
    </div>
    <div class="feature-card">
        <h3>Zdjęcia</h3>
        <p>Twoje wspomnienia zapisane w galerii.</p>
    </div>
</div>