@page "/"
@namespace TravelPlannerApp.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Travel Planner</title>
    <base href="~/" />
    <link rel="stylesheet" href="/css/app.css?v=29" />
    <style>
:root{
    --bg:#eef4ff;
    --bg2:#f8fbff;
    --card:#ffffff;
    --text:#2a0f22;
    --muted:#8b647f;
    --primary:#eb2595;
    --primary-dark:#d81d7e;
    --primary-soft:#dbeafe;
    --accent:#d4067b;
    --danger:#ef4444;
    --danger-soft:#fee2e2;
    --ok:#16a34a;
    --ok-soft:#dcfce7;
    --line:#e2e8f0;
    --shadow:0 22px 50px rgba(42, 15, 28, 0.1);
    --shadow-soft:0 14px 30px rgba(235, 37, 119, 0.08);
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
    margin:0;
    min-height:100vh;
    background:
        radial-gradient(circle at top left, rgba(235, 37, 169, 0.18), transparent 34rem),
        radial-gradient(circle at bottom right, rgba(212, 6, 140, 0.12), transparent 32rem),
        linear-gradient(135deg,var(--bg),var(--bg2));
    font-family:"Segoe UI",Inter,Arial,sans-serif;
    color:var(--text);
}
a{color:var(--primary);text-decoration:none;font-weight:650}
a:hover{text-decoration:none;color:var(--primary-dark)}
button,.button{
    border:0;
    border-radius:16px;
    padding:12px 18px;
    cursor:pointer;
    background:#e8eef8;
    color:#8b255a;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    font-weight:750;
    letter-spacing:.01em;
    transition:transform .18s ease,box-shadow .18s ease,background .18s ease,opacity .18s ease;
}
button:hover,.button:hover{transform:translateY(-1px);box-shadow:0 12px 24px rgba(15,23,42,.10)}
button:active,.button:active{transform:translateY(0)}
.primary{background:linear-gradient(135deg,var(--primary),#f63ba5);color:white;box-shadow:0 14px 28px rgba(235, 37, 192, 0.24)}
.primary:hover{background:linear-gradient(135deg,var(--primary-dark),#eb259c);color:white}
.danger{background:var(--danger);color:white}
.ghost{background:transparent;box-shadow:none;color:var(--muted)}
.ghost:hover{background:#f1f5f9;box-shadow:none;color:var(--text)}
.danger-text{color:var(--danger)!important}
.full{width:100%}
.shell{display:flex;min-height:100vh;padding:18px;gap:22px}
.sidebar{
    width:285px;
    background:linear-gradient(180deg,#531638,#6c2950 62%,#a52f6e);
    color:white;
    padding:24px;
    position:sticky;
    top:18px;
    height:calc(100vh - 36px);
    border-radius:30px;
    box-shadow:var(--shadow);
    overflow:hidden;
}
.sidebar::before{
    content:"";
    position:absolute;
    width:190px;height:190px;
    border-radius:999px;
    background:rgba(246, 59, 196, 0.28);
    filter:blur(10px);
    right:-85px;top:-70px;
}
.brand{
    position:relative;
    display:flex;
    align-items:center;
    gap:12px;
    font-weight:900;
    font-size:22px;
    margin-bottom:32px;
    letter-spacing:-.02em;
}
.brand-mark{
    display:grid;
    place-items:center;
    width:44px;height:44px;
    border-radius:16px;
    background:linear-gradient(135deg,#fa60ba,#ee22a3);
    box-shadow:0 12px 28px rgba(238, 34, 153, 0.22);
}
.sidebar nav{position:relative;display:grid;gap:10px}
.sidebar a{
    color:#dbeafe;
    padding:13px 14px;
    border-radius:17px;
    display:flex;
    align-items:center;
    gap:10px;
    font-weight:750;
    transition:.18s ease;
}
.sidebar a.active,.sidebar a:hover{
    background:rgba(255,255,255,.12);
    color:white;
    transform:translateX(3px);
}
.sidebar-footer{
    position:absolute;
    left:24px;right:24px;bottom:24px;
    border:1px solid rgba(255,255,255,.12);
    background:rgba(255,255,255,.08);
    border-radius:22px;
    padding:16px;
    backdrop-filter:blur(12px);
}
.sidebar-footer p{margin:0 0 4px;font-weight:800}
.sidebar-footer small{display:block;color:#febfe5;line-height:1.45;margin-bottom:14px}
.logout-link{justify-content:center;background:rgba(255,255,255,.12);padding:11px!important;color:white!important;border-radius:15px!important}
.content{flex:1;padding:18px 8px 28px;max-width:1280px;margin:0 auto;width:100%}
.page-header,.row-between{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:18px}
h1{font-size:clamp(30px,4vw,46px);line-height:1.05;margin:0 0 12px;letter-spacing:-.04em;color:#2a0f1d}
h2{margin:0 0 16px;font-size:22px;letter-spacing:-.025em}
h3{margin:8px 0 8px;font-size:18px}.muted{color:var(--muted)}
.eyebrow{
    display:inline-flex;
    width:max-content;
    align-items:center;
    gap:6px;
    padding:7px 11px;
    border-radius:999px;
    background:var(--primary-soft);
    color:#d81d97;
    font-size:12px;
    font-weight:900;
    text-transform:uppercase;
    letter-spacing:.08em;
    margin-bottom:14px;
}
.hero,.card,.auth-card,.feature-card{
    background:rgba(255,255,255,.86);
    border:1px solid rgba(240, 226, 234, 0.92);
    border-radius:30px;
    padding:28px;
    box-shadow:var(--shadow-soft);
    backdrop-filter:blur(12px);
}
.hero{position:relative;overflow:hidden;background:linear-gradient(135deg,rgba(255,255,255,.94),rgba(254, 219, 239, 0.9));box-shadow:var(--shadow)}
.hero::after{
    content:"";
    position:absolute;
    width:270px;height:270px;
    border-radius:999px;
    background:linear-gradient(135deg,rgba(235, 37, 192, 0.2),rgba(212, 6, 130, 0.16));
    right:-90px;top:-95px;
}
.hero-dashboard{display:grid;grid-template-columns:1fr;align-items:center;gap:28px;margin-bottom:24px}
.hero p{font-size:17px;line-height:1.7;max-width:880px;color:var(--muted);margin:0 0 22px}.hero-actions{display:flex;gap:12px;flex-wrap:wrap}.hero-card{position:relative;z-index:1;background:#0f172a;color:white;border-radius:26px;padding:24px;display:grid;gap:6px;box-shadow:0 22px 45px rgba(15,23,42,.22)}
.hero-card span{color:#fd93e1;font-weight:800;text-transform:uppercase;font-size:12px;letter-spacing:.08em}.hero-card b{font-size:28px}.hero-card small{color:#cbd5e1}.feature-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}.feature-card{min-height:160px;transition:transform .18s ease,box-shadow .18s ease}.feature-card:hover{transform:translateY(-4px);box-shadow:var(--shadow)}.feature-card span{font-size:32px}.feature-card p{color:var(--muted);line-height:1.55;margin:0}
.grid{display:grid;gap:22px}.two{grid-template-columns:repeat(2,minmax(0,1fr))}.wide{grid-column:1/-1}.narrow{max-width:680px}.form{display:grid;gap:12px}.form label{font-weight:750;color:#55334c;font-size:14px}.form input,.form select,.inline-form input,input,select{
    width:100%;
    padding:13px 15px;
    border:1px solid var(--line);
    border-radius:16px;
    background:white;
    color:var(--text);
    outline:none;
    transition:border .18s ease,box-shadow .18s ease;
}
.form input:focus,.form select:focus,.inline-form input:focus,input:focus,select:focus{border-color:#fd93dd;box-shadow:0 0 0 4px rgba(248, 147, 253, 0.25)}
.alert{padding:13px 15px;border-radius:16px;background:#eef2ff;margin:12px 0;color:#a3306f;border:1px solid #fec7ea;font-weight:650}.alert.danger{background:var(--danger-soft);color:#991b1b;border-color:#fecaca}.alert.success{background:var(--ok-soft);color:#65164c;border-color:#f7bbf1}
.auth-page{min-height:100vh;display:grid;place-items:center;padding:26px;background:radial-gradient(circle at 18% 12%,rgba(235, 37, 169, 0.24),transparent 28rem),linear-gradient(135deg,#2a0f23,#8a1e6b 55%,#d406a7)}
.auth-card{width:min(470px,94vw);margin:0;box-shadow:0 30px 80px rgba(42, 15, 30, 0.35);border-color:rgba(255,255,255,.42)}.login-card{text-align:left}.auth-logo{width:62px;height:62px;display:grid;place-items:center;border-radius:22px;background:linear-gradient(135deg,#eb25ba,#ee22b8);color:white;font-size:30px;box-shadow:0 18px 34px rgba(235, 37, 156, 0.28);margin-bottom:18px}.demo-box{padding:12px 14px;background:#fcf8fb;border:1px dashed #e1cbd9;border-radius:16px;margin:16px 0;color:#55334a}.auth-link{display:inline-block;margin-top:16px}.trip-row{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line);padding:15px 0;gap:16px}.trip-row:last-child{border-bottom:0}.trip-row b{font-size:16px}.trip-row span{color:#694760}.trip-row small{color:#b894ae}.clickable{cursor:pointer}.clickable:hover b{color:var(--primary)}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:20px 0}.stat{background:linear-gradient(180deg,#fff,#f8fafc);border:1px solid var(--line);border-radius:24px;padding:20px;box-shadow:var(--shadow-soft);position:relative;overflow:hidden}.stat::before{content:"";position:absolute;inset:0 0 auto;height:4px;background:linear-gradient(90deg,var(--primary),var(--accent))}.stat span{display:block;color:var(--muted);font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px}.stat b{font-size:22px;letter-spacing:-.03em}.tabs{display:flex;gap:10px;flex-wrap:wrap;margin:20px 0}.tabs button{border-radius:999px;background:white;border:1px solid var(--line);box-shadow:none}.tabs button.active{background:linear-gradient(135deg,var(--primary),#f63bae);color:white;border-color:transparent;box-shadow:0 12px 22px rgba(235, 37, 176, 0.22)}
.modal{position:fixed;inset:0;background:rgba(42, 15, 32, 0.5);display:grid;place-items:center;z-index:50;backdrop-filter:blur(8px)}.modal-box{background:white;border-radius:26px;padding:28px;min-width:340px;box-shadow:var(--shadow);border:1px solid var(--line)}.modal-box button+button{margin-left:8px}.gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:14px;margin-top:18px}.gallery img{width:100%;height:150px;object-fit:cover;border-radius:20px;border:1px solid var(--line);box-shadow:0 12px 24px rgba(42, 15, 32, 0.1);transition:.18s ease}.gallery img:hover{transform:scale(1.025)}.progress{height:16px;background:#ebe5e8;border-radius:999px;overflow:hidden;border:1px solid #efdbe6}.progress span{display:block;height:100%;background:linear-gradient(90deg,var(--primary),var(--accent));transition:.25s;border-radius:999px}.packed{text-decoration:line-through;color:var(--muted)}.packing-item label{display:flex;align-items:center;gap:12px;flex-wrap:wrap}.qty-badge{display:inline-flex!important;align-items:center;justify-content:center;padding:5px 10px;border-radius:999px;background:#ffeef9;color:#d81d93!important;font-size:12px;font-weight:800;text-decoration:none!important}.packed .qty-badge{opacity:.65}.inline-form{display:grid;grid-template-columns:1fr 120px auto;gap:10px;margin:16px 0}.settings-card{display:grid;gap:18px}.switch-row{padding:18px;border:1px solid var(--line);border-radius:22px;background:#f8fafc}.switch-row span{display:grid;gap:4px}.switch-row small{color:var(--muted)}input[type="checkbox"]{width:22px;height:22px;accent-color:var(--primary)}
@@media(max-width:1050px){.feature-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.hero-dashboard{grid-template-columns:1fr}.hero-card{max-width:420px}.sidebar{width:255px}}
@@media(max-width:900px){.shell{display:block;padding:0}.sidebar{width:auto;height:auto;position:static;border-radius:0 0 28px 28px}.sidebar-footer{position:static;margin-top:18px}.two,.stats,.feature-grid{grid-template-columns:1fr}.content{padding:18px}.inline-form{grid-template-columns:1fr}.page-header{display:block}}
@@media(max-width:560px){.hero,.card,.auth-card,.feature-card{padding:20px;border-radius:24px}button,.button{width:100%}.trip-row{align-items:flex-start;flex-direction:column}.hero-actions{display:grid}.stats{gap:12px}}

    </style>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />
    <script src="_framework/blazor.server.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="js/map.js"></script>
</body>
</html>
